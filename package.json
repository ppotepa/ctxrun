{
  "name": "ctxrun",
  "version": "0.1.1",
  "description": "Run commands with an explicit user context across sudo/root boundaries.",
  "author": "Paweł Potępa <pawel.potepa@hotmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ppotepa/ctxrun.git"
  },
  "homepage": "https://github.com/ppotepa/ctxrun",
  "bugs": {
    "url": "https://github.com/ppotepa/ctxrun/issues"
  },
  "type": "module",
  "bin": {
    "ctxrun": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "node --loader ts-node/esm src/cli/index.ts",
    "test:unit": "npm run build && node --test dist/registry/*.test.js",
    "test:e2e:build": "docker build -f e2e/Dockerfile -t ctxrun-e2e .",
    "test:e2e": "npm run test:e2e:build && docker run --rm ctxrun-e2e",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sudo",
    "cli",
    "context",
    "github-cli",
    "git"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
